# GitHub read access (primary, then fallback) — used only for GET/clone/fetch, never a write verb.
GH_TOKEN=
GITHUB_PAT=

# LLM gateway — precedence: LLM_BASE_URL > GPT_OSS_ENDPOINT; LLM_API_KEY > PROFESSIONALIZE_API_KEY > GPT_OSS_API_KEY
LLM_BASE_URL=
LLM_API_KEY=
GPT_OSS_ENDPOINT=https://llm.professionalize.com/v1/
GPT_OSS_API_KEY=
PROFESSIONALIZE_API_KEY=

# Optional overrides
LLM_MODEL=gpt-oss
LLM_TIMEOUT_SECONDS=90

# Optional: override where disposable clones/evidence are written (default: ./runs, cwd-relative)
README_AGENT_RUNS_DIR=
